amends "package://github.com/jdx/hk/releases/download/v1.48.0/hk@1.48.0#/Config.pkl"

hooks {
  ["pre-commit"] {
    fix = true
    stash = true
    steps {
      ["biome"] {
        glob = List("**/*.js", "**/*.jsx", "**/*.ts", "**/*.tsx", "**/*.css", "**/*.json")
        check = "mise :biome {{ files }}"
        fix = "mise :biome --write {{ files }}"
      }
    }
  }
  ["pre-push"] {
    steps {
      ["verify"] {
        check = "mise :verify"
      }
    }
  }
}
